<UserControl x:Class="Bookmarkaa.BookmarkItemSmall"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Bookmarkaa"
             mc:Ignorable="d" Background="Transparent"
             Height="28" d:DesignWidth="640">
    <Grid>

        <Rectangle x:Name="Icon" Height="20" Width="20" Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Rectangle.Fill>
                <ImageBrush ImageSource="{Binding IconPath}"/>
            </Rectangle.Fill>
        </Rectangle>

        <TextBlock x:Name="GroupName" Text="{Binding Name}" ToolTip="{Binding Folder}"
                   Margin="34,0,34,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>

        <Button x:Name="BtnDelete"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Width="22" Height="22" Margin="0,0,6,0"
                Content="×" FontWeight="Bold" FontSize="13" Padding="0"
                Visibility="Collapsed"
                Click="BtnDelete_Click"
                ToolTip="Usuń zakładkę"/>

    </Grid>
</UserControl>
