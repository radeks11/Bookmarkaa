<Window x:Class="Bookmarkaa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Bookmarkaa.Helpers.Controls"
        xmlns:local="clr-namespace:Bookmarkaa"
        mc:Ignorable="d"
        Style="{StaticResource {x:Type Window}}"
        Title="Bookmarkaa" Height="800" Width="600" Background="#FF2F2F2F" Closing="Window_Closing"
        KeyDown="Window_KeyDown" WindowStartupLocation="Manual" Loaded="Window_Loaded">
    <Grid Background="{x:Null}">

        <TextBox x:Name="SearchBox" Margin="10,10,10,0" VerticalAlignment="Top" Height="26"
                 Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF555555" CaretBrush="White"
                 TextChanged="SearchBox_TextChanged" PreviewKeyDown="SearchBox_PreviewKeyDown"/>

        <controls:ListViewEx x:Name="BookmarksList" Background="{x:Null}" BorderBrush="{x:Null}"
                             Margin="10,42,10,40" ItemsSource="{Binding Items}" SelectionMode="Single"
                             MouseLeftButtonUp="BookmarksList_MouseLeftButtonUp">

            <controls:ListViewEx.ItemTemplate>
                <DataTemplate>
                    <local:BookmarkItemSmall/>
                </DataTemplate>
            </controls:ListViewEx.ItemTemplate>
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="#FF515151"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF707070"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF626262"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </controls:ListViewEx>
        <StatusBar x:Name="Status" Background="{x:Null}" VerticalAlignment="Bottom" Height="20" >
            <TextBlock x:Name="StatusEdit" Text="Shift: Edit element" Foreground="White" Margin="10,0,20,0"/>
            <TextBlock x:Name="StatusSort" Text="Ctrl-Q: Enable Sort Mode" Foreground="White" Margin="0,0,20,0" MouseDown="StatusSort_MouseDown"/>
            <TextBlock x:Name="StatusSave" Text="Ctrl-S: Save" Foreground="White" Margin="0,0,20,0" MouseDown="StatusSave_MouseDown"/>
        </StatusBar>

    </Grid>
</Window>
